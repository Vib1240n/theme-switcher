/* ===========================================================================
 * rust-widgets - Generated by theme-switcher
 * Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
 * Do NOT edit by hand - run theme-apply to regenerate.
 * ===========================================================================*/

/* Window transparency - critical for Hyprland blur */
window,
window.background,
.background,
headerbar,
decoration,
windowhandle {
  background-color: transparent;
  background-image: none;
  box-shadow: none;
  border: none;
}

window > * {
  background-color: transparent;
}

/* ===========================================================================
 * Widget Containers
 * ===========================================================================*/
.widget-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_widget }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  border-radius: {{ radius.container }}px;
  padding: 16px;
}

.popup-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_popup }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  border-radius: {{ radius.container }}px;
  padding: 12px;
  box-shadow: 0 8px 32px alpha({{ color.shadow }}, {{ opacity.shadow }});
}

/* ===========================================================================
 * COMMON - Typography
 * ===========================================================================*/
separator {
  background: alpha({{ color.border }}, 0.25);
  min-height: 1px;
  margin: 12px 0;
}

.section-title {
  color: alpha({{ color.accent }}, 0.8);
  font-size: {{ sizing.font_small }}px;
  font-weight: 600;
  letter-spacing: 0.5px;
  margin-top: 12px;
  margin-bottom: 6px;
}

.section-title:first-child {
  margin-top: 0;
}

/* ===========================================================================
 * COMMON - Progress Bars
 * ===========================================================================*/
progressbar {
  min-height: 6px;
  margin-top: 4px;
  margin-bottom: 8px;
}

progressbar trough {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border-radius: {{ radius.small }}px;
  min-height: 6px;
}

progressbar progress {
  background-color: {{ color.accent }};
  border-radius: {{ radius.small }}px;
  min-height: 6px;
}

progressbar.warning progress { background-color: {{ color.yellow }}; }
progressbar.critical progress { background-color: {{ color.red }}; }

/* ===========================================================================
 * COMMON - Sliders / Scales
 * ===========================================================================*/
scale trough {
  background: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border-radius: {{ radius.badge }}px;
  min-height: 6px;
}

scale highlight {
  background: {{ color.accent }};
  border-radius: {{ radius.badge }}px;
}

scale slider {
  background: {{ color.fg }};
  border-radius: {{ radius.circle }}%;
  min-width: 16px;
  min-height: 16px;
  margin: -5px;
  box-shadow: 0 2px 4px alpha({{ color.shadow }}, {{ opacity.shadow }});
}

scale slider:hover {
  background: {{ color.fg_pure }};
}

scale.muted highlight {
  background: alpha({{ color.fg }}, {{ opacity.fg_faint }});
}

/* ===========================================================================
 * COMMON - Buttons
 * ===========================================================================*/
button {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border: none;
  border-radius: {{ radius.row }}px;
  padding: 8px 12px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  transition: all 150ms ease;
}

button:hover {
  background: alpha({{ color.accent }}, 0.25);
  color: {{ color.fg }};
}

button.flat {
  background: transparent;
}

button.flat:hover {
  background: alpha({{ color.accent }}, 0.2);
}

button.circular {
  border-radius: {{ radius.circle }}%;
  padding: 8px;
  min-width: 36px;
  min-height: 36px;
}

button.destructive-action {
  background: alpha({{ color.red }}, 0.2);
  color: {{ color.red }};
}

button.destructive-action:hover {
  background: alpha({{ color.red }}, 0.3);
}

/* ===========================================================================
 * COMMON - Switches
 * ===========================================================================*/
switch {
  background: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border-radius: {{ radius.row }}px;
  min-width: 48px;
  min-height: 24px;
}

switch:checked { background: {{ color.accent }}; }

switch slider {
  background: {{ color.fg }};
  border-radius: {{ radius.circle }}%;
  min-width: 20px;
  min-height: 20px;
  margin: 2px;
}

/* ===========================================================================
 * COMMON - Empty State & Urgency
 * ===========================================================================*/
.empty-state {
  padding: 16px;
}

.empty-label {
  font-size: {{ sizing.font_section }}px;
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-style: italic;
}

.urgency-low {
  opacity: 0.85;
}

.urgency-critical {
  border-color: {{ color.red }};
  background-color: alpha({{ color.bg_critical }}, {{ opacity.bg_popup }});
}

/* ===========================================================================
 * STATS-POPUP
 * ===========================================================================*/
.stat-row { margin: 4px 0; }

.stat-label {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_section }}px;
  min-width: 80px;
}

.stat-value {
  color: {{ color.fg }};
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
}

.stat-item {
  padding: 8px 12px;
  background: alpha({{ color.bg_elevated }}, {{ opacity.section }});
  border-radius: {{ radius.row }}px;
}

.stat-icon {
  font-size: {{ sizing.font_base }}px;
  color: {{ color.accent }};
  margin-right: 6px;
}

.temp-label {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_small }}px;
}

.temp-value {
  color: {{ color.fg }};
  font-size: {{ sizing.font_small }}px;
  font-weight: 500;
}

.temp-warning { color: {{ color.yellow }}; }
.temp-critical { color: {{ color.red }}; }

/* ===========================================================================
 * CONTROL-CENTER - Toggles
 * ===========================================================================*/
.toggles-section { margin-bottom: 4px; }
.toggle-grid { margin: 4px 0; }

.toggle-btn {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.section }}px;
  padding: 12px;
  min-width: 56px;
  min-height: 56px;
  border: none;
  transition: all 200ms ease;
}

.toggle-btn:hover {
  background: alpha({{ color.accent }}, 0.25);
}

.toggle-btn.active {
  background: {{ color.accent }};
}

.toggle-btn.active label {
  color: {{ color.bg }};
}

.toggle-btn box { spacing: 4px; }

.toggle-icon {
  font-size: 20px;
  color: {{ color.fg }};
}

.toggle-btn.active .toggle-icon {
  color: {{ color.bg }};
}

.toggle-label {
  font-size: 9px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.toggle-btn.active .toggle-label {
  color: {{ color.bg }};
}

/* ===========================================================================
 * CONTROL-CENTER - Sliders
 * ===========================================================================*/
.sliders-section { margin: 4px 0; }
.slider-row { margin: 8px 0; }

.slider-icon {
  font-size: 18px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  min-width: 28px;
}

.slider-row scale { margin: 0 8px; }
.slider-row scale trough { min-height: 8px; }
.slider-row scale slider { min-width: 18px; min-height: 18px; }

.slider-value {
  font-size: {{ sizing.font_section }}px;
  color: {{ color.fg }};
  min-width: 36px;
}

.output-selector {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.icon }}px;
  padding: 4px 8px;
  margin-top: 4px;
  border: none;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_small }}px;
}

.output-selector:hover {
  background: alpha({{ color.bg_elevated }}, 0.7);
}

/* ===========================================================================
 * CONTROL-CENTER - Media Section
 * ===========================================================================*/
.media-section {
  background: alpha({{ color.bg_elevated }}, {{ opacity.section }});
  border-radius: {{ radius.section }}px;
  padding: 12px;
  margin: 4px 0;
}

.media-section.inactive { opacity: 0.5; }

.media-art {
  border-radius: {{ radius.icon }}px;
  min-width: 48px;
  min-height: 48px;
  background: alpha({{ color.bg_elevated }}, {{ opacity.input }});
}

.media-info { margin-left: 12px; }

.media-title {
  font-size: 13px;
  font-weight: 600;
  color: {{ color.fg }};
}

.media-artist {
  font-size: {{ sizing.font_small }}px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.media-controls { margin-top: 8px; }

.media-btn {
  background: transparent;
  border: none;
  padding: 8px;
  border-radius: {{ radius.circle }}%;
  color: {{ color.fg }};
}

.media-btn:hover {
  background: alpha({{ color.accent }}, 0.25);
}

.media-btn.play {
  background: {{ color.accent }};
  color: {{ color.bg }};
}

.media-btn.play:hover {
  background: alpha({{ color.accent }}, 0.85);
}

/* ===========================================================================
 * CONTROL-CENTER - Stats Section
 * ===========================================================================*/
.stats-section { margin-top: 4px; }
.stats-row { margin: 2px 0; }

/* ===========================================================================
 * VOLUME-CONTROL
 * ===========================================================================*/
.device-selector { margin-bottom: 12px; }

.device-button {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.row }}px;
  padding: 10px 14px;
  border: none;
  transition: all 200ms ease;
}

.device-button:hover {
  background: alpha({{ color.accent }}, 0.25);
}

.device-button.active {
  background: alpha({{ color.accent }}, 0.2);
  border: {{ sizing.border_width }}px solid alpha({{ color.accent }}, 0.4);
}

.device-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  margin-right: 8px;
}

.device-button.active .device-icon {
  color: {{ color.accent }};
}

.device-name {
  font-size: {{ sizing.font_section }}px;
  color: {{ color.fg }};
}

.device-button.active .device-name {
  color: {{ color.fg_pure }};
}

.device-check {
  color: {{ color.accent }};
  margin-left: 8px;
}

.master-volume {
  background: alpha({{ color.bg_elevated }}, {{ opacity.section }});
  border-radius: {{ radius.section }}px;
  padding: 14px;
  margin-bottom: 12px;
}

.volume-row { margin: 0; }

.volume-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  min-width: 24px;
}

.volume-icon.muted { color: {{ color.red }}; }

.mute-button {
  background: transparent;
  border: none;
  padding: 6px;
  border-radius: {{ radius.icon }}px;
  min-width: 36px;
  min-height: 36px;
}

.mute-button:hover {
  background: alpha({{ color.accent }}, 0.2);
}

.mute-button.muted {
  background: alpha({{ color.red }}, 0.2);
}

.mute-button.muted:hover {
  background: alpha({{ color.red }}, 0.3);
}

.volume-slider { margin: 0 12px; }
.volume-slider trough { min-height: 8px; }
.volume-slider slider { min-width: 18px; min-height: 18px; }

.volume-value {
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: {{ color.fg }};
  min-width: 40px;
}

.volume-value.muted {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
}

.section-separator {
  background: alpha({{ color.border }}, 0.25);
  min-height: 1px;
  margin: 12px 0;
}

.app-volumes { margin-top: 4px; }

.app-row {
  background: alpha({{ color.bg_elevated }}, 0.35);
  border-radius: {{ radius.row }}px;
  padding: 10px 12px;
  margin-bottom: 6px;
}

.app-row:last-child { margin-bottom: 0; }

.app-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  min-width: 20px;
  margin-right: 10px;
}

.app-info { margin-right: 8px; }

.app-name {
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: {{ color.fg }};
}

.app-stream {
  font-size: {{ sizing.font_tiny }}px;
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
}

.app-slider trough { min-height: 6px; }
.app-slider slider { min-width: 14px; min-height: 14px; margin: -4px; }

.app-volume-value {
  font-size: {{ sizing.font_small }}px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  min-width: 32px;
}

.app-mute-btn {
  background: transparent;
  border: none;
  padding: 4px;
  border-radius: {{ radius.badge }}px;
  min-width: 28px;
  min-height: 28px;
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
}

.app-mute-btn:hover {
  background: alpha({{ color.accent }}, 0.2);
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.app-mute-btn.muted {
  color: {{ color.red }};
}

.input-section { margin-top: 4px; }

.input-volume {
  background: alpha({{ color.bg_elevated }}, 0.35);
  border-radius: {{ radius.row }}px;
  padding: 12px;
}

.input-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.input-icon.muted {
  color: {{ color.red }};
}

.app-scroll {
  min-height: 60px;
  max-height: 200px;
}

.app-scroll undershoot,
.app-scroll overshoot {
  background: none;
}

/* ===========================================================================
 * MEDIA-PLAYER
 * ===========================================================================*/
.album-art-frame {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border-radius: {{ radius.container - 1 }}px {{ radius.container - 1 }}px 0 0;
  min-height: 320px;
  margin: 0;
  padding: 0;
}

.album-art {
  border-radius: {{ radius.container - 1 }}px {{ radius.container - 1 }}px 0 0;
  margin: 0;
  padding: 0;
}

.controls-container { padding: 16px; margin: 0; }

.track-info { margin-bottom: 8px; }

.track-title {
  color: {{ color.fg }};
  font-size: {{ sizing.font_base }}px;
  font-weight: 500;
}

.track-artist {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_section }}px;
  margin-top: 2px;
}

.progress-section { margin-bottom: 4px; }
.progress-bar { min-height: 4px; }

.progress-bar trough {
  background-color: alpha({{ color.fg }}, 0.2);
  border-radius: 2px;
  min-height: 4px;
}

.progress-bar highlight {
  background-color: {{ color.fg }};
  border-radius: 2px;
}

.progress-bar slider {
  background-color: {{ color.fg }};
  border-radius: {{ radius.circle }}%;
  min-width: 12px;
  min-height: 12px;
  margin: -4px;
}

.time-labels { margin-top: 4px; }

.time-position,
.time-duration {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_tiny }}px;
  font-family: monospace;
}

.playback-controls { margin: 12px 0 8px 0; }

.control-btn {
  background-color: transparent;
  border: none;
  border-radius: {{ radius.circle }}%;
  padding: 8px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  min-width: 44px;
  min-height: 44px;
}

.control-btn:hover {
  color: {{ color.fg }};
}

.control-btn image {
  -gtk-icon-size: 24px;
}

.play-btn {
  background-color: {{ color.fg }};
  color: {{ color.bg }};
  min-width: 56px;
  min-height: 56px;
}

.play-btn:hover {
  background-color: alpha({{ color.fg }}, 0.9);
  color: {{ color.bg }};
}

.play-btn image {
  -gtk-icon-size: 28px;
}

.volume-section { margin-top: 8px; }

.volume-section .volume-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  -gtk-icon-size: 16px;
  min-width: 24px;
}

.volume-section .volume-slider trough {
  background-color: alpha({{ color.fg }}, 0.2);
  min-height: 4px;
}

.volume-section .volume-slider highlight {
  background-color: alpha({{ color.fg }}, 0.6);
}

.volume-section .volume-slider slider {
  min-width: 12px;
  min-height: 12px;
  margin: -4px;
}

.volume-label {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
  min-width: 36px;
  font-family: monospace;
}

.player-selector { margin-bottom: 8px; }

.player-dot {
  background-color: alpha({{ color.fg }}, 0.2);
  border: none;
  border-radius: {{ radius.circle }}%;
  min-width: 32px;
  min-height: 32px;
  padding: 6px;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.player-dot:hover {
  background-color: alpha({{ color.fg }}, 0.3);
  color: {{ color.fg }};
}

.player-dot.active {
  background-color: alpha({{ color.fg }}, 0.4);
  color: {{ color.fg }};
}

.player-dot image { -gtk-icon-size: 16px; }

/* ===========================================================================
 * NOTIFICATION CENTER (unified - was standalone palette previously)
 * ===========================================================================*/

.nc-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_widget }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  border-radius: {{ radius.container + 4 }}px;
  padding: 0;
  min-width: 400px;
}

.nc-header {
  padding: 24px;
  border-bottom: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.2);
}

.nc-bell-wrapper {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.section }}px;
  padding: 8px;
}

.nc-bell-icon {
  color: {{ color.fg }};
  -gtk-icon-style: symbolic;
}

.nc-title {
  font-size: 18px;
  font-weight: 500;
  color: {{ color.fg }};
}

.nc-subtitle {
  font-size: 13px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  margin-top: 2px;
}

.nc-settings-btn {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.icon }}px;
  padding: 8px;
  border: none;
  min-width: 36px;
  min-height: 36px;
}

.nc-settings-btn:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
}

.nc-settings-btn image {
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  -gtk-icon-style: symbolic;
}

.nc-settings-btn:hover image {
  color: {{ color.fg }};
}

.nc-scroll {
  background-color: transparent;
}

.nc-scroll undershoot.top,
.nc-scroll undershoot.bottom,
.nc-scroll overshoot.top,
.nc-scroll overshoot.bottom {
  background: none;
}

.nc-list {
  background-color: transparent;
  padding: 12px;
}

.nc-list row {
  background-color: transparent;
  padding: 0;
  margin-bottom: 8px;
}

.nc-list row:last-child {
  margin-bottom: 0;
}

.nc-row {
  background-color: transparent;
  border: none;
  padding: 0;
}

.nc-card {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.2);
  border-radius: {{ radius.card }}px;
  padding: 16px;
  transition: all 200ms ease;
}

.nc-card:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
}

.nc-icon-wrapper {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.section }}px;
  padding: 8px;
  min-width: 36px;
  min-height: 36px;
}

.nc-icon-info {
  background-color: alpha({{ color.blue }}, 0.15);
}

.nc-icon-success {
  background-color: alpha({{ color.green }}, 0.15);
}

.nc-icon-warning {
  background-color: alpha({{ color.yellow }}, 0.15);
}

.nc-icon-error {
  background-color: alpha({{ color.red }}, 0.15);
}

.nc-type-icon {
  -gtk-icon-style: symbolic;
}

.nc-icon-color-info { color: {{ color.blue }}; }
.nc-icon-color-success { color: {{ color.green }}; }
.nc-icon-color-warning { color: {{ color.yellow }}; }
.nc-icon-color-error { color: {{ color.red }}; }

.nc-card-content { padding: 0; }

.nc-card-title {
  font-size: {{ sizing.font_base }}px;
  font-weight: 500;
  color: {{ color.fg }};
}

.nc-card-app {
  font-size: {{ sizing.font_small }}px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  margin-top: 1px;
}

.nc-card-time {
  font-size: {{ sizing.font_small }}px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.nc-card-body {
  font-size: 13px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  margin-top: 6px;
  line-height: 1.4;
}

.nc-dismiss-btn {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.icon }}px;
  padding: 6px;
  border: none;
  min-width: 24px;
  min-height: 24px;
  opacity: 0;
  transition: opacity 200ms ease;
}

.nc-card:hover .nc-dismiss-btn {
  opacity: 1;
}

.nc-dismiss-btn:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
}

.nc-dismiss-label {
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.nc-dismiss-btn:hover .nc-dismiss-label {
  color: {{ color.fg }};
}

.nc-empty {
  padding: 48px 24px;
}

.nc-empty-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  -gtk-icon-style: symbolic;
}

.nc-empty-label {
  font-size: {{ sizing.font_base }}px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.nc-footer {
  padding: 16px;
  border-top: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.2);
}

.nc-clear-btn {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.row }}px;
  padding: 12px 16px;
  border: none;
  transition: all 200ms ease;
}

.nc-clear-btn:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
}

.nc-trash-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  -gtk-icon-style: symbolic;
}

.nc-clear-label {
  font-size: {{ sizing.font_base }}px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
}

.nc-clear-btn:hover .nc-trash-icon,
.nc-clear-btn:hover .nc-clear-label {
  color: {{ color.fg }};
}

.nc-card-progress {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.small }}px;
  min-height: 4px;
}

.nc-card-progress progress {
  background-color: {{ color.blue }};
  border-radius: {{ radius.small }}px;
}

.nc-card-actions { margin-top: 8px; }

.nc-action-btn {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.icon }}px;
  padding: 6px 12px;
  border: none;
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
}

.nc-action-btn:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
  color: {{ color.fg }};
}

/* Popup notification styles */
.popup-header { margin-bottom: 8px; }

.popup-app-icon {
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  -gtk-icon-style: symbolic;
}

.popup-app-name {
  font-size: {{ sizing.font_section }}px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
}

.popup-close {
  background-color: transparent;
  border: none;
  padding: 4px 8px;
  border-radius: {{ radius.badge }}px;
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  min-width: 20px;
  min-height: 20px;
}

.popup-close:hover {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  color: {{ color.fg }};
}

.popup-summary {
  font-size: {{ sizing.font_base }}px;
  font-weight: 500;
  color: {{ color.fg }};
}

.popup-body {
  font-size: 13px;
  font-weight: 400;
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  margin-top: 4px;
}

.popup-image { border-radius: {{ radius.icon }}px; }

.popup-progress {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.small }}px;
  min-height: 4px;
  margin-top: 8px;
}

.popup-progress progress {
  background-color: {{ color.blue }};
  border-radius: {{ radius.small }}px;
}

.popup-actions { margin-top: 12px; }

.popup-action-btn {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.icon }}px;
  padding: 6px 12px;
  border: none;
  font-size: {{ sizing.font_section }}px;
  font-weight: 500;
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
}

.popup-action-btn:hover {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
  color: {{ color.fg }};
}

.urgency-low {
  border-left: 3px solid alpha({{ color.blue }}, 0.5);
}

.urgency-critical {
  border-left: 3px solid {{ color.red }};
}

/* ===========================================================================
 * VOLUME OSD / BRIGHTNESS OSD
 * ===========================================================================*/
.osd-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_popup }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  border-radius: {{ radius.container + 8 }}px;
  padding: 12px 20px;
  min-width: 200px;
}

.osd-icon {
  color: {{ color.fg }};
  opacity: 0.9;
}

.osd-icon.muted {
  color: {{ color.red }};
  opacity: 0.7;
}

.osd-scale { margin: 0 4px; }

.osd-scale trough {
  background: alpha({{ color.bg_elevated }}, 0.8);
  border-radius: {{ radius.small }}px;
  min-height: 8px;
}

.osd-scale highlight {
  background: {{ color.accent }};
  border-radius: {{ radius.small }}px;
  min-height: 8px;
}

.osd-scale.muted highlight {
  background: alpha({{ color.red }}, 0.6);
}

.osd-scale slider {
  background: transparent;
  border: none;
  box-shadow: none;
  min-width: 0;
  min-height: 0;
  margin: 0;
  padding: 0;
}

.osd-percent {
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  font-size: 13px;
  font-weight: 500;
  font-family: monospace;
}
