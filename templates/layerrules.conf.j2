# ===========================================================================
# Hyprland layer rules - Generated by theme-switcher
# Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
# Source from hyprland.conf with:
#   source = ~/.config/hypr/layerrules-themed.conf
# ===========================================================================

# AGS bar
layerrule = blur on, ignore_alpha {{ visual.layer["ags-bar"] }}, match:namespace ags-bar

# cliphist-gui
layerrule = blur on, ignore_alpha {{ visual.layer["cliphist-gui"] }}, match:namespace cliphist-gui

# launch-gui
layerrule = blur on, ignore_alpha {{ visual.layer["launch-gui"] }}, match:namespace launch-gui

# rust-widgets (control-center, stats-popup, media-player, volume-control, notification-center)
layerrule = blur on, ignore_alpha {{ visual.layer["rust-widgets"] }}, match:namespace rust-widgets

# rust-widgets popups (volume OSD, brightness OSD, notification popups)
layerrule = blur on, ignore_alpha {{ visual.layer["rust-widgets-popup"] }}, xray 0, blur_popups on, match:namespace rust-widgets-popup
