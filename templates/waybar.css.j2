/* ===========================================================================
 * waybar colors - Generated by theme-switcher
 * Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
 * Import from waybar/style.css with:  @import "colors.css";
 * ===========================================================================*/

@define-color bg          {{ color.bg }};
@define-color bg_elevated {{ color.bg_elevated }};
@define-color bg_critical {{ color.bg_critical }};
@define-color fg          {{ color.fg }};
@define-color fg_pure     {{ color.fg_pure }};
@define-color border      {{ color.border }};
@define-color accent      {{ color.accent }};
@define-color red         {{ color.red }};
@define-color yellow      {{ color.yellow }};
@define-color green       {{ color.green }};
@define-color blue        {{ color.blue }};

/* Common module styling - waybar uses these directly */
* {
  font-family: "{{ sizing.font_family }}", sans-serif;
  font-size: {{ sizing.font_bar }}px;
  color: @fg;
  min-height: 0;
}

window#waybar {
  background: alpha(@bg, {{ opacity.bg }});
  border: {{ sizing.border_width }}px solid alpha(@border, {{ opacity.border }});
  border-radius: {{ radius.container }}px;
}

#workspaces button {
  color: alpha(@fg, {{ opacity.fg_muted }});
  background: transparent;
  border-radius: {{ radius.row }}px;
  padding: 0 8px;
  margin: 2px;
}

#workspaces button:hover {
  background: alpha(@bg_elevated, {{ opacity.bg_elevated }});
  color: @fg;
}

#workspaces button.active {
  background: alpha(@bg_elevated, {{ opacity.input }});
  color: @accent;
}

#clock,
#battery,
#network,
#pulseaudio,
#tray,
#cpu,
#memory,
#temperature,
#disk {
  padding: 0 10px;
  margin: 0 2px;
  border-radius: {{ radius.icon }}px;
  background: alpha(@bg_elevated, {{ opacity.bg_elevated }});
}

#battery.critical {
  color: @red;
}

#battery.warning {
  color: @yellow;
}
