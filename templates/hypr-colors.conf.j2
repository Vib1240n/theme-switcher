# ===========================================================================
# hyprland colors - Generated by theme-switcher
# Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
# Source from hyprland.conf with:  source = ~/.config/hypr/colors.conf
# ===========================================================================

general {
    col.active_border   = rgb({{ color.accent | hex }}) rgb({{ color.vim_normal | hex }}) 45deg
    col.inactive_border = rgba({{ color.border | hex }}aa)
    border_size         = {{ sizing.border_width + 1 }}
}

decoration {
    rounding = {{ radius.row }}
    shadow {
        enabled       = true
        range         = 12
        render_power  = 3
        color         = rgba({{ color.shadow | hex }}{{ opacity.shadow | alpha_hex }})
        color_inactive = rgba({{ color.shadow | hex }}66)
    }
}

group {
    col.border_active   = rgb({{ color.accent | hex }})
    col.border_inactive = rgba({{ color.border | hex }}aa)
    groupbar {
        col.active   = rgb({{ color.accent | hex }})
        col.inactive = rgba({{ color.bg_elevated | hex }}aa)
        text_color   = rgb({{ color.fg | hex }})
    }
}
