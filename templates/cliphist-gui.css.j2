/* ===========================================================================
 * cliphist-gui - Generated by theme-switcher
 * Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
 * Do NOT edit by hand - run theme-apply to regenerate.
 * ===========================================================================*/
window,
window.background,
.background,
headerbar,
decoration,
windowhandle {
  background-color: transparent;
  background-image: none;
  box-shadow: none;
  border: none;
}

window > * {
  background-color: transparent;
}

.clip-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_container }});
  border-radius: {{ radius.container }}px;
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  padding: 0;
}

/* -- Header -- */

.clip-header {
  padding: 20px 24px 4px 24px;
}

.clip-search-row {
  margin-bottom: 4px;
}

.clip-search {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.2);
  border-radius: {{ radius.input }}px;
  padding: 10px 14px;
  color: {{ color.fg }};
  font-size: {{ sizing.font_base + 1 }}px;
  min-height: 22px;
}

.clip-search:focus {
  border-color: alpha({{ color.accent }}, 0.5);
}

.clip-esc-badge {
  background-color: alpha({{ color.border }}, 0.35);
  border-radius: {{ radius.badge }}px;
  padding: 3px 8px;
  font-size: {{ sizing.font_small }}px;
  font-weight: 600;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  margin-right: 4px;
}

.clip-hint-text {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
}

.clip-section-label {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_section }}px;
  font-weight: 600;
  padding: 8px 4px 4px 4px;
}

/* -- Tab Bar -- */

.clip-tab-bar {
  padding: 8px 24px 4px 24px;
  border-bottom: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.15);
}

.clip-tab {
  padding: 8px 16px;
  margin-right: 8px;
  border-radius: {{ radius.input }}px {{ radius.input }}px 0 0;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: 13px;
  font-weight: 500;
  transition: all 150ms ease;
}

.clip-tab:hover {
  color: alpha({{ color.fg }}, {{ opacity.fg_normal }});
  background-color: alpha({{ color.border }}, 0.10);
}

.clip-tab-active {
  color: {{ color.fg }};
  background-color: alpha({{ color.accent }}, {{ opacity.selected }});
  border-bottom: 2px solid {{ color.accent }};
}

/* -- List -- */

.clip-list {
  background-color: transparent;
}

.clip-list row {
  background-color: transparent;
  border-radius: {{ radius.row }}px;
  margin: 1px 8px;
  padding: 10px 14px;
  transition: background-color 150ms ease;
}

.clip-list row:hover {
  background-color: alpha({{ color.accent }}, {{ opacity.hover }});
}

.clip-list row:selected {
  background-color: alpha({{ color.accent }}, {{ opacity.selected }});
}

.clip-list row:drop(active) {
  background-color: alpha({{ color.accent }}, 0.25);
  border: {{ sizing.border_width }}px dashed {{ color.accent }};
}

/* -- Pin Icon -- */

.clip-pin-icon {
  min-width: 20px;
  min-height: 20px;
}

.clip-pin-icon-img {
  opacity: 0.8;
  -gtk-icon-filter: drop-shadow(0 0 1px alpha({{ color.accent }}, 0.5));
}

.clip-pin-icon-fallback {
  color: {{ color.accent }};
  font-size: {{ sizing.font_section }}px;
  font-weight: bold;
}

/* -- Thumbnails & Icons -- */

.clip-thumb-frame {
  border-radius: {{ radius.icon }}px;
  min-width: {{ sizing.icon_box }}px;
  min-height: {{ sizing.icon_box }}px;
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
}

.clip-thumb {
  border-radius: {{ radius.icon }}px;
}

.clip-text-icon {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
  border-radius: {{ radius.icon }}px;
  min-width: {{ sizing.icon_box }}px;
  min-height: {{ sizing.icon_box }}px;
}

.clip-text-icon-label {
  color: alpha({{ color.accent }}, 0.6);
  font-size: 20px;
  font-weight: bold;
}

/* -- Content -- */

.clip-title {
  color: {{ color.fg }};
  font-size: {{ sizing.font_base }}px;
  font-weight: 600;
}

.clip-subtitle {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
  margin-top: 1px;
}

/* -- Badge -- */

.clip-badge {
  background-color: transparent;
  font-size: {{ sizing.font_tiny }}px;
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-weight: 600;
  letter-spacing: 0.5px;
}

.clip-badge-pinned {
  color: alpha({{ color.accent }}, 0.6);
}

.clip-time {
  color: alpha({{ color.fg }}, {{ opacity.fg_faint }});
  font-size: {{ sizing.font_tiny }}px;
  margin-top: 2px;
}

/* -- Status Bar -- */

.clip-status-bar {
  padding: 10px 24px;
  border-top: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.15);
}

.clip-status-left {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
}

.clip-status-key {
  background-color: alpha({{ color.border }}, 0.30);
  border-radius: {{ radius.small }}px;
  padding: 1px 6px;
  font-size: {{ sizing.font_tiny }}px;
  font-weight: 600;
  color: alpha({{ color.fg }}, 0.45);
}

.clip-status-hint {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_tiny }}px;
  margin-left: 4px;
}

/* -- Vim Mode Indicator -- */

.vim-mode-indicator {
  font-family: monospace;
  font-weight: bold;
  font-size: {{ sizing.font_tiny }}px;
  padding: 2px 8px;
  border-radius: {{ radius.small }}px;
  margin-right: 12px;
}

.vim-mode-normal {
  background: {{ color.vim_normal }};
  color: {{ color.vim_bg }};
}

.vim-mode-insert {
  background: {{ color.vim_insert }};
  color: {{ color.vim_bg }};
}
