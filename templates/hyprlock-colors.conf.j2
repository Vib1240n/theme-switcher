# Use these variables in your hyprlock.conf:
#   $bg         = $hl_bg
#   $accent     = $hl_accent
#   etc.

$hl_bg         = rgba({{ color.bg | hex }}ff)
$hl_bg_alt     = rgba({{ color.bg_elevated | hex }}ff)
$hl_fg         = rgba({{ color.fg | hex }}ff)
$hl_fg_dim     = rgba({{ color.fg | hex }}{{ opacity.fg_muted | alpha_hex }})
$hl_accent     = rgba({{ color.accent | hex }}ff)
$hl_border     = rgba({{ color.border | hex }}ff)
$hl_red        = rgba({{ color.red | hex }}ff)
$hl_green      = rgba({{ color.green | hex }}ff)
$hl_yellow     = rgba({{ color.yellow | hex }}ff)
$hl_shadow     = rgba({{ color.shadow | hex }}{{ opacity.shadow | alpha_hex }})
