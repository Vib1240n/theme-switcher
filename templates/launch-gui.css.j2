/* ===========================================================================
 * launch-gui - Generated by theme-switcher
 * Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
 * Do NOT edit by hand - run theme-apply to regenerate.
 * ===========================================================================*/

window,
window.background,
.background,
headerbar,
decoration,
windowhandle {
  background-color: transparent;
  background-image: none;
  box-shadow: none;
  border: none;
}

window > * {
  background-color: transparent;
}

/* -- Container -- */
.launch-container {
  background-color: alpha({{ color.bg }}, {{ opacity.bg_container }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  padding: 0;
}

.launch-container.collapsed {
  border-radius: {{ radius.container_pill }}px;
}

.launch-container.expanded {
  border-radius: {{ radius.container }}px;
}

/* -- Search Wrapper -- */
.launch-search-wrapper {
  padding: 12px 16px;
}

.launch-container.expanded .launch-search-wrapper {
  padding: 16px 20px 8px 20px;
}

/* -- Search Row -- */
.launch-search-row {
  margin: 0;
}

.launch-search {
  background-color: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.2);
  border-radius: {{ radius.input }}px;
  padding: 12px 16px;
  color: {{ color.fg }};
  font-size: {{ sizing.font_base + 1 }}px;
  min-height: 22px;
}

.launch-container.collapsed .launch-search {
  border-radius: {{ radius.container }}px;
}

.launch-search:focus {
  border-color: alpha({{ color.accent }}, 0.5);
}

.launch-esc-badge {
  background-color: alpha({{ color.border }}, 0.35);
  border-radius: {{ radius.badge }}px;
  padding: 3px 8px;
  font-size: {{ sizing.font_small }}px;
  font-weight: 600;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  margin-right: 4px;
}

.launch-hint-text {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
}

/* -- Section Label -- */
.launch-section-label {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  font-size: {{ sizing.font_section }}px;
  font-weight: 600;
  padding: 8px 24px 4px 24px;
}

/* -- List -- */
.launch-list {
  background-color: transparent;
  padding: 0 8px;
}

.launch-list row {
  background-color: transparent;
  border-radius: {{ radius.row }}px;
  margin: 1px 0;
  padding: 10px 14px;
  transition: background-color 150ms ease;
}

.launch-list row:hover {
  background-color: alpha({{ color.accent }}, {{ opacity.hover }});
}

.launch-list row:selected {
  background-color: alpha({{ color.accent }}, {{ opacity.selected }});
}

/* -- Icons -- */
.launch-icon-box {
  background-color: alpha({{ color.bg_elevated }}, 0.8);
  border-radius: {{ radius.icon }}px;
  min-width: {{ sizing.icon_box }}px;
  min-height: {{ sizing.icon_box }}px;
}

.launch-icon-fallback {
  color: alpha({{ color.accent }}, 0.6);
  font-size: 20px;
  font-weight: bold;
}

/* -- Content -- */
.launch-title {
  color: {{ color.fg }};
  font-size: {{ sizing.font_base }}px;
  font-weight: 600;
}

.launch-subtitle {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
  margin-top: 1px;
}

.launch-calc-result {
  color: {{ color.accent }};
  font-size: 18px;
}

/* -- Status Bar -- */
.launch-status-bar {
  padding: 10px 20px;
  border-top: {{ sizing.border_width }}px solid alpha({{ color.border }}, 0.15);
}

.launch-status-left {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_small }}px;
}

.launch-status-key {
  background-color: alpha({{ color.border }}, 0.3);
  border-radius: {{ radius.small }}px;
  padding: 1px 6px;
  font-size: {{ sizing.font_tiny }}px;
  font-weight: 600;
  color: alpha({{ color.fg }}, 0.45);
}

.launch-status-hint {
  color: alpha({{ color.fg }}, {{ opacity.fg_dim }});
  font-size: {{ sizing.font_tiny }}px;
  margin-left: 4px;
}

/* -- Vim Mode Indicator -- */
.vim-mode-indicator {
  font-family: monospace;
  font-weight: bold;
  font-size: {{ sizing.font_tiny }}px;
  padding: 2px 8px;
  border-radius: {{ radius.small }}px;
  margin-right: 12px;
}

.vim-mode-normal {
  background: {{ color.vim_normal }};
  color: {{ color.vim_bg }};
}

.vim-mode-insert {
  background: {{ color.vim_insert }};
  color: {{ color.vim_bg }};
}
