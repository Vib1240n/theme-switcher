/* ===========================================================================
 * AGS Bar - Generated by theme-switcher
 * Palette: {{ meta.palette_name }}   Visual: {{ meta.visual_name }}
 * Do NOT edit by hand - run theme-apply to regenerate.
 * ===========================================================================*/

window,
window.background,
.background,
headerbar,
decoration,
windowhandle {
  background-color: transparent;
  background-image: none;
  box-shadow: none;
  border: none;
}

window > * {
  background-color: transparent;
}

* {
  font-family: "{{ sizing.font_family }}", "{{ sizing.font_family_mono }}", sans-serif;
  font-size: {{ sizing.font_bar }}px;
  color: {{ color.fg }};
}

/* Bar Container */
window.bar {
  background: alpha({{ color.bg }}, {{ opacity.bg }});
  border-radius: {{ radius.container }}px;
  border: {{ sizing.border_width }}px solid alpha({{ color.border }}, {{ opacity.border }});
  margin: 6px 10px 0 10px;
  min-height: 40px;
}

centerbox.bar-inner {
  padding: 0 10px;
  min-height: 40px;
}

/* Workspaces */
box.workspaces {
  padding: 0 4px;
  min-height: 28px;
}

box.workspaces button {
  background: transparent;
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  padding: 4px 10px;
  margin: 2px;
  border-radius: {{ radius.row }}px;
  min-width: 28px;
  min-height: 24px;
  border: none;
}

box.workspaces button:hover {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  color: {{ color.fg }};
}

box.workspaces button.active {
  background: alpha({{ color.bg_elevated }}, {{ opacity.input }});
  color: {{ color.accent }};
  font-weight: 600;
}

box.special {
  padding: 0 4px;
}

/* Clock */
button.clock {
  font-family: "{{ sizing.font_family_bar }}", "{{ sizing.font_family }}", sans-serif;
  font-weight: 500;
  font-size: {{ sizing.font_bar }}px;
  color: {{ color.fg }};
  padding: 4px 16px;
  margin: 0 6px 0 10px;
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
  border-radius: {{ radius.row }}px;
  border: none;
  min-height: 28px;
}

button.clock:hover {
  background: alpha({{ color.accent }}, 0.2);
  color: {{ color.accent }};
}

/* Right-side modules (Volume/Network/Battery/ControlCenter/BluetoothBattery) */
button.module {
  padding: 4px 10px;
  margin: 0 2px;
  background: transparent;
  border: none;
  border-radius: {{ radius.icon }}px;
  min-height: 28px;
  color: {{ color.fg }};
}

button.module:hover {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
}

button.module .module-label {
  margin-left: 6px;
  font-size: {{ sizing.font_base }}px;
}

button.module.critical {
  color: {{ color.red }};
}

button.module.warning {
  color: {{ color.yellow }};
}

@keyframes flash {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.3; }
}

button.module.critical-flash {
  animation: flash 1s ease-in-out infinite;
}

/* Tray */
box.tray {
  padding: 0 8px;
  min-height: 28px;
}

box.tray .tray-item,
box.tray menubutton {
  padding: 2px 6px;
  margin: 0 1px;
  background: transparent;
  border: none;
  min-height: 24px;
  border-radius: {{ radius.badge }}px;
}

box.tray .tray-item:hover,
box.tray menubutton:hover {
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
}

/* Caffeinate */
button.caffeinate {
  color: alpha({{ color.fg }}, {{ opacity.fg_muted }});
  padding: 4px 8px;
  margin: 0 4px;
  background: transparent;
  border: none;
  border-radius: {{ radius.badge }}px;
  font-family: "{{ sizing.font_family_mono }}";
  font-size: {{ sizing.font_bar }}px;
  min-height: 28px;
}

button.caffeinate:hover {
  color: {{ color.accent }};
  background: alpha({{ color.bg_elevated }}, {{ opacity.bg_elevated }});
}

button.caffeinate.active {
  color: {{ color.accent }};
}

image {
  -gtk-icon-size: 18px;
}
